{:paths   ["test/clj"]
 :deps    {org.clojure/clojure           {:mvn/version "1.12.4"}
           iot.github.amiorin/big-config {:local/root "<{ project-dir }>"}}
 :aliases {:test {:extra-deps  {expound/expound                      {:mvn/version "0.9.0"}
                                io.github.cognitect-labs/test-runner {:git/url "https://github.com/cognitect-labs/test-runner.git"
                                                                      :git/tag "v0.5.1"
                                                                      :git/sha "dfb30dd"}
                                pjstadig/humane-test-output          {:mvn/version "0.11.0"}
                                org.clojure/tools.namespace          {:mvn/version "1.5.0"}
                                com.lambdaisland/classpath           {:mvn/version "0.6.58"}
                                babashka/babashka                    {:mvn/version "1.12.215"}
                                integrant/repl                       {:mvn/version "0.5.0"}
                                integrant/integrant                  {:mvn/version "1.0.1"}}
                  :exec-fn      cognitect.test-runner.api/test
                  :main-opts   ["-e" "(require 'pjstadig.humane-test-output) (pjstadig.humane-test-output/activate!)"
                                "-m" "cognitect.test-runner" "--dir" "test/clj"]}}}
